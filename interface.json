{
    "interface_version": 2,
    "name": "arknights-auto-operator",
    "label": "明日方舟自动凹图",
    "version": "v0.1.0",
    "icon": "logo.png",
    "description": "帧级自动凹图 + 费用条计时 + 打轴对轴（MaaFramework 方案二 + PySide6）",
    "github": "https://github.com/Windsland52/ArknightsAutoOperator",
    "controller": [
        {
            "name": "Win32-PC",
            "label": "PC 官方客户端 (Arknights.exe)",
            "type": "Win32",
            "win32": {
                "window_regex": "明日方舟",
                "class_regex": "UnityWndClass",
                "screencap": "FramePool",
                "mouse": "PostMessage",
                "keyboard": "PostMessage"
            },
            "display_short_side": 720
        },
        {
            "name": "Android",
            "label": "安卓 / 模拟器 (ADB)",
            "type": "Adb",
            "display_short_side": 720
        }
    ],
    "resource": [
        {
            "name": "base",
            "label": "Base",
            "path": ["./resource/base"]
        }
    ],
    "import": ["./tasks/farm.json"]
}
